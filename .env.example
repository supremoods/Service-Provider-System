# Public API base URL (used by client requests)
# Include the API version path suffix if your backend expects it.
NEXT_PUBLIC_API_URL=https://service-provider-service.onrender.com/sps/v1/

# Cookie names used by the frontend auth layer
NEXT_PUBLIC_ACCESS_TOKEN_COOKIE_NAME=access_token
NEXT_PUBLIC_REFRESH_TOKEN_COOKIE_NAME=refresh_token
NEXT_PUBLIC_CSRF_TOKEN_COOKIE_NAME=csrf_token

